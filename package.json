{
  "name": "tmd-coder",
  "version": "0.1.0",
  "description": "TMD Coder - AI编程助手",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tmd": "dist/cli.js",
    "tmd-coder": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-assistant",
    "deepseek",
    "cli",
    "typescript"
  ],
  "author": "Tuimeo Inc. with AI",
  "license": "Apache License 2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "axios": "^1.7.9",
    "fs-extra": "^11.2.0",
    "execa": "^9.4.0",
    "winston": "^3.15.0",
    "cosmiconfig": "^9.0.0",
    "chalk": "^5.4.1",
    "ora": "^8.1.1",
    "inquirer": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/ui": "^2.1.8"
  },
  "files": [
    "dist",
    "README.md",
    "ARCH.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tuimeo/tmdcoder.git"
  },
  "bugs": {
    "url": "https://github.com/tuimeo/tmdcoder/issues"
  },
  "homepage": "https://github.com/tuimeo/tmdcoder#readme"
}